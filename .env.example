# Public API base (no trailing slash). Swagger: same host + /docs
# Produção (Railway)
NEXT_PUBLIC_API_URL=https://apex-keys-api-production.up.railway.app
# API local (opcional)
# NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Opcional: base só para IGDB (src/services/api.ts). Se omitido, usa a mesma base que NEXT_PUBLIC_API_URL (getApiBaseUrl).
# NEXT_PUBLIC_APEX_API_URL=https://apex-keys-api-production.up.railway.app

# Logs detalhados [Apex IGDB] no console (útil em produção/Vercel). Dev já activa logs sem isto.
# NEXT_PUBLIC_DEBUG_IGDB=1

# Optional: RAWG key for admin game search UI (see README)
# NEXT_PUBLIC_RAWG_API_KEY=
